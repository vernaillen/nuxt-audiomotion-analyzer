{
  "name": "nuxt-audiomotion-analyzer",
  "version": "0.0.3",
  "description": "Nuxt audiomotion analyzer",
  "repository": "vernaillen/nuxt-audiomotion-analyzer",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build prepare && nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "typecheck": "vue-tsc --noEmit && pnpm -r --filter='!nuxt-audiomotion-analyzer' typecheck"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "audiomotion-analyzer": "^4.5.4"
  },
  "devDependencies": {
    "@nuxt/devtools": "4.0.0-alpha.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.2",
    "@types/node": "^25.6.0",
    "changelogen": "^0.6.2",
    "eslint": "^10.2.1",
    "nuxt": "^4.4.2",
    "typescript": "latest",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820"
}
